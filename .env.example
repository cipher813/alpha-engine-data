# Alpha Engine Data — environment variables
# Copy to .env and fill in values. .env is gitignored.

# Phase 1: universe returns (polygon.io free tier, 5 calls/min)
POLYGON_API_KEY=your_polygon_api_key

# Phase 1: macro data (FRED, free)
FRED_API_KEY=your_fred_api_key

# Phase 2: analyst consensus + EPS revisions (FMP free tier, 250 req/day)
FMP_API_KEY=your_fmp_api_key

# Phase 2: insider + institutional data (SEC EDGAR requires identity)
EDGAR_IDENTITY=YourName email@domain.com

# LAMBDA_SKIP
# Vars below this line are local-only (not deployed to Lambda)
AWS_PROFILE=default
