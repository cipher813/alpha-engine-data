# Alpha Engine — Master Environment Variables
# Copy to .env and fill in values. .env is gitignored.
#
# This is the SINGLE SOURCE OF TRUTH for all API keys and secrets.
# Run `bash infrastructure/sync-secrets.sh` to push to EC2 instances.
# Lambda deploy scripts read from this file automatically.
#
# ─── LLM / AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=alpha-research
VOYAGE_API_KEY=

# ─── Market Data APIs ────────────────────────────────────────────────────────
POLYGON_API_KEY=
FMP_API_KEY=
FRED_API_KEY=

# ─── SEC EDGAR ────────────────────────────────────────────────────────────────
# Format: "Your Name your@email.com" (SEC requires contact info)
EDGAR_IDENTITY=

# ─── Email (Gmail SMTP primary, SES fallback) ────────────────────────────────
EMAIL_SENDER=
EMAIL_RECIPIENTS=
GMAIL_APP_PASSWORD=

# ─── RAG / Vector DB ─────────────────────────────────────────────────────────
RAG_DATABASE_URL=

# ─── GitHub (repo access for spot instances) ──────────────────────────────────
GITHUB_TOKEN=

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=alpha-engine-research

# LAMBDA_SKIP
# ─── Local-only (below this line, NOT deployed to Lambda) ─────────────────────
# Lambda has its own IAM role; these are only for local dev and EC2 cron.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
