{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alpha Engine Predictions",
  "description": "Predictor output consumed by executor and dashboard. Written daily to predictor/predictions/{date}.json and predictor/predictions/latest.json.",
  "type": "object",
  "required": ["date", "model_version", "n_predictions", "predictions"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "model_version": {
      "type": "string",
      "description": "Model identifier (e.g. meta-v3.0-5models)"
    },
    "model_hit_rate_30d": {
      "type": ["number", "null"],
      "description": "30-day directional hit rate"
    },
    "n_predictions": {
      "type": "integer",
      "minimum": 0
    },
    "n_high_confidence": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "predictions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prediction_entry"
      }
    }
  },
  "$defs": {
    "prediction_entry": {
      "type": "object",
      "required": ["ticker", "predicted_direction", "prediction_confidence", "predicted_alpha"],
      "properties": {
        "ticker": {
          "type": "string"
        },
        "predicted_direction": {
          "type": "string",
          "enum": ["UP", "DOWN", "FLAT"]
        },
        "prediction_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "predicted_alpha": {
          "type": "number",
          "description": "Predicted 5-day market-relative return"
        },
        "p_up": { "type": "number", "minimum": 0, "maximum": 1 },
        "p_flat": { "type": "number", "minimum": 0, "maximum": 1 },
        "p_down": { "type": "number", "minimum": 0, "maximum": 1 },
        "combined_rank": {
          "type": ["integer", "null"],
          "description": "Cross-sectional rank (1 = highest alpha)"
        },
        "gbm_veto": {
          "type": "boolean",
          "description": "True if negative alpha + bottom-half rank"
        },
        "momentum_confirmation": {
          "type": ["number", "null"],
          "description": "Momentum model score"
        },
        "expected_move": {
          "type": ["number", "null"],
          "description": "Volatility model expected move"
        },
        "regime_bull": { "type": ["number", "null"] },
        "regime_bear": { "type": ["number", "null"] },
        "research_calibrator_prob": {
          "type": ["number", "null"],
          "description": "P(research signal correct) from calibrator"
        },
        "meta_model_version": { "type": ["string", "null"] },
        "price_data_age_days": { "type": ["integer", "null"] },
        "watchlist_source": { "type": ["string", "null"] },
        "mse_rank": { "type": ["number", "null"] },
        "model_rank": { "type": ["number", "null"] }
      }
    }
  }
}
